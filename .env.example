# Скопируй этот файл в .env и подставь свои значения.
# .env коммитить нельзя — он в .gitignore.

# ============================================================
# Telegram
# ============================================================
# Токен бота от @BotFather. Формат: 1234567890:AA...
# Получить: открой @BotFather → /newbot → следуй инструкции.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ============================================================
# AI (опционально)
# ============================================================
# Бот поддерживает любой OpenAI-compatible API:
#   - OpenAI
#   - Polza AI (пример ниже)
#   - другие совместимые провайдеры
#
# Если AI_ENABLED=false или OPENAI_API_KEY пустой,
# бот работает в обычном режиме — кнопка «🤖 Спросить ИИ»
# просто не появляется в меню (graceful degradation).

# Включить AI-режим: true / false. По умолчанию выключен.
AI_ENABLED=false

# API-ключ провайдера. Никогда не коммить настоящий ключ.
OPENAI_API_KEY=your_api_key_here

# Base URL провайдера. Оставь пустым для стандартного OpenAI.
# Пример для Polza AI: https://polza.ai/api/v1
OPENAI_BASE_URL=

# Название модели у провайдера.
# Пример для Polza AI: google/gemini-3.1-flash-lite
# Пример для OpenAI:   gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# ------------------------------------------------------------
# Пример конфигурации для Polza AI (раскомментируй и подставь ключ):
#
# AI_ENABLED=true
# OPENAI_API_KEY=your_api_key_here
# OPENAI_BASE_URL=https://polza.ai/api/v1
# OPENAI_MODEL=google/gemini-3.1-flash-lite
# ------------------------------------------------------------

# ============================================================
# Прочее
# ============================================================
# Уровень логирования: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
