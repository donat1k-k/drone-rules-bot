# Скопируй этот файл в .env и подставь реальные значения.
# .env НЕ коммитить — он в .gitignore.

# --- Telegram ---
# Токен бота от @BotFather. Формат: 1234567890:AA...
TELEGRAM_BOT_TOKEN=

# --- AI (опционально) ---
# Если оба ключа пустые — бот работает без AI-режима, только база знаний.
# Использовать только ОДИН из провайдеров.

# OpenAI-совместимый провайдер
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Anthropic (альтернатива)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Прочее ---
# Уровень логирования: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Включить AI-режим. Если false — пункт меню "Спросить ИИ" будет скрыт.
AI_ENABLED=false
