# Скопируй этот файл в .env и подставь реальные значения.
# .env НЕ коммитить — он в .gitignore.

# --- Telegram ---
# Токен бота от @BotFather. Формат: 1234567890:AA...
TELEGRAM_BOT_TOKEN=

# --- AI (опционально) ---
# Поддерживается любой OpenAI-compatible API (OpenAI, Polza AI, и др.).
# Если ключ пустой или AI_ENABLED=false — бот работает без AI, только база знаний.

# Включить AI-режим (true / false). По умолчанию выключен.
AI_ENABLED=false

# API-ключ провайдера
OPENAI_API_KEY=

# Base URL провайдера. Оставь пустым для стандартного OpenAI.
# Polza AI: https://api.polza.ai/v1
# Любой другой OpenAI-compatible: укажи его URL
OPENAI_BASE_URL=

# Название модели провайдера
OPENAI_MODEL=gpt-4o-mini

# --- Прочее ---
# Уровень логирования: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
